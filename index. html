<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>跨越80年的电子情书 - 日本遗孤</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Microsoft YaHei', '微软雅黑', sans-serif;
            background: #1a1a1a;
            color: #e0e0e0;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* ========== 通用样式 ========== */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 20px;
            position: relative;
            overflow: hidden;
        }

        /* ========== 第一幕：迟到的真相 ========== */
        #act1 {
            background: linear-gradient(135deg, #0d0d0d 0%, #1a1a2e 100%);
            position: relative;
        }

        .act1-content {
            position: relative;
            width: 100%;
            max-width: 900px;
        }

        .barrage-container {
            position: relative;
            height: 400px;
            background: rgba(0,0,0,0.7);
            border: 2px solid #404040;
            margin-bottom: 40px;
            overflow: hidden;
        }

        .barrage {
            position: absolute;
            color: #ff6b6b;
            font-size: 18px;
            white-space: nowrap;
            animation: barrageFloat linear forwards;
            text-shadow: 0 0 8px rgba(255,107,107,0.5);
            font-weight: bold;
        }

        @keyframes barrageFloat {
            from {
                right: -500px;
                opacity: 1;
            }
            to {
                right: 100vw;
                opacity: 0.3;
            }
        }

        .silhouette {
            position: absolute;
            right: 50px;
            top: 50%;
            transform: translateY(-50%);
            width: 150px;
            height: 200px;
            background: linear-gradient(135deg, #333 0%, #222 100%);
            border-radius: 50% 50% 45% 45%;
            opacity: 0.6;
            filter: blur(2px);
        }

        .barrage-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 40px;
        }

        .stat-card {
            background: linear-gradient(135deg, #2a2a3e 0%, #1f1f2e 100%);
            padding: 25px;
            border-left: 4px solid #4a90e2;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect fill="none" stroke="%23404040" stroke-width="0.5" width="10" height="10"/></svg>');
            opacity: 0.1;
        }

        .stat-number {
            font-size: 32px;
            color: #4a90e2;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .stat-label {
            font-size: 14px;
            color: #a0a0a0;
        }

        /* ========== 第二幕：断裂的童年 ========== */
        #act2 {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        }

        .map-container {
            position: relative;
            width: 100%;
            max-width: 900px;
        }

        .map-wrapper {
            background: linear-gradient(135deg, #2a4a5e 0%, #1a3a4e 100%);
            padding: 40px;
            border: 3px dashed #5a7a8e;
            position: relative;
            overflow: hidden;
        }

        .map-wrapper::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 50%, rgba(200,100,100,0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 30%, rgba(100,150,200,0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        .cities-grid {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
            margin-bottom: 30px;
        }

        .city-card {
            background: rgba(255,255,255,0.05);
            padding: 20px;
            border: 2px solid #4a7a8e;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }

        .city-card:hover {
            background: rgba(255,255,255,0.1);
            border-color: #6a9aae;
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(106,154,174,0.3);
        }

        .city-name {
            font-size: 20px;
            font-weight: bold;
            color: #6a9aae;
            margin-bottom: 10px;
        }

        .city-data {
            display: none;
            font-size: 14px;
            color: #c0c0c0;
            padding-top: 10px;
            border-top: 1px solid #4a7a8e;
            margin-top: 10px;
        }

        .city-card.active .city-data {
            display: block;
            animation: fadeInUp 0.5s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .map-timeline {
            position: relative;
            z-index: 1;
            padding: 20px;
            background: rgba(0,0,0,0.3);
            border-left: 4px solid #e67e22;
        }

        .timeline-item {
            margin-bottom: 15px;
            padding-left: 20px;
            position: relative;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -10px;
            top: 5px;
            width: 8px;
            height: 8px;
            background: #e67e22;
            border-radius: 50%;
        }

        .timeline-date {
            color: #e67e22;
            font-weight: bold;
            font-size: 12px;
        }

        .timeline-text {
            color: #a0a0a0;
            font-size: 13px;
        }

        /* ========== 第三幕：两个妈，一个娃（重点） ========== */
        #act3 {
            background: linear-gradient(135deg, #0d0d0d 0%, #1a0a0a 100%);
            position: relative;
        }

        .act3-wrapper {
            width: 100%;
            max-width: 1000px;
        }

        .identity-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            margin-bottom: 60px;
            align-items: center;
        }

        .identity-side {
            position: relative;
        }

